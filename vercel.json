{
    "build": {
        "env": {
            "DJANGO_SETTINGS_MODULE": "config.settings"
        }
    },
    "functions": {
        "documentos/upload/**/*.py": {
            "maxDuration": 300
        },
        "validacao/**/*.py": {
            "maxDuration": 300
        }
    },
    "routes": [
        {
            "src": "/static/(.*)",
            "headers": {
                "Cache-Control": "public, max-age=31536000, immutable"
            }
        },
        {
            "src": "/(.*)",
            "dest": "/"
        }
    ]
}
