{
    "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput",
    "builds": [
        {
            "src": "config/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb",
                "runtime": "python3.12"
            }
        }
    ],
    "build": {
        "env": {
            "DJANGO_SETTINGS_MODULE": "config.settings"
        }
    },
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1",
            "headers": {
                "Cache-Control": "public, max-age=31536000, immutable"
            }
        },
        {
            "src": "/(.*)",
            "dest": "/config/wsgi.py"
        }
    ]
}
