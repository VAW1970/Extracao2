# ============================================================
# Extracao Contabil — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# Django
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — Neon (pooled for app traffic, unpooled for migrations)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# LLM Provider — "ollama" for local dev, "api" for production
LLM_PROVIDER=api

# Ollama (local dev only — ignored in production)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# External LLM API — NVIDIA (OpenAI-compatible endpoint)
LLM_API_KEY=
LLM_MODEL=nvidia/nemotron-3-ultra-550b-a55b
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
VISION_LLM_MODEL=meta/llama-3.2-90b-vision-instruct

# Extraction retries (max attempts before marking precisa_revisao)
EXTRACTION_MAX_RETRIES=2

# Supabase Storage (production) — file uploads saved here instead of local disk
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET_NAME=documentos
